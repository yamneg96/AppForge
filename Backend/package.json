    "@types/node": "^20.10.6",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.14",
    "@types/cookie-parser": "^1.4.7",
